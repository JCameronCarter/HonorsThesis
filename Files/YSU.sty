%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Custom abstract environment

\renewenvironment{abstract}{\clearpage\stepcounter{THESISpages}
